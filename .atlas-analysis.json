  "keyFeatures": [
    "Endpoint discovery and registry for ML models and data sources",
    "GitHub-style endpoint URLs (/{owner}/{endpoint-slug})",
    "Flexible visibility controls (public, internal, private)",
    "Organization collaboration with role-based access control",
    "Federated Identity Provider with RS256-signed satellite tokens",
    "Official Python, TypeScript, and Go SDKs",
    "CLI tool for endpoint management",
    "Star/trending system for discovering popular endpoints",
    "Full-stack application with React frontend and FastAPI backend",
    "Docker-based deployment with PostgreSQL and Redis"
  ],
